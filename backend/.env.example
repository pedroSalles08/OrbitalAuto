# ── Configurações do OrbitalAuto ──────────────────────────────────

# URL base do sistema Orbital
ORBITAL_BASE_URL=https://orbital.iffarroupilha.edu.br

# Origens permitidas para CORS (separar por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Tempo de expiração da sessão em horas
SESSION_EXPIRY_HOURS=4

# Máximo de sessões simultâneas
MAX_SESSIONS=100

# Porta do servidor
PORT=8000

# Modo debug
DEBUG=false

# Publicacao web minima (monolito servindo o frontend estatico)
DESKTOP_MODE=true

# Barreira simples de acesso antes do app
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=troque-esta-senha

# Debug do Orbital deve ficar desligado em ambiente publico
ENABLE_DEBUG_ROUTES=false
